// ============================================
// Town of Arkaoda - Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Kullanici ----

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  players   Player[]
}

// ---- Oda ----

model Room {
  id         String     @id @default(cuid())
  code       String     @unique
  hostId     String
  status     RoomStatus @default(WAITING)
  minPlayers Int        @default(3)
  maxPlayers Int        @default(10)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  players    Player[]
  messages   Message[]
  gameLogs   GameLog[]
}

// ---- Oyuncu (bir odadaki kullanici) ----

model Player {
  id       String   @id @default(cuid())
  userId   String
  roomId   String
  role     Role?
  isAlive  Boolean  @default(true)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userId, roomId])
  @@index([roomId])
  @@index([userId])
}

// ---- Mesaj ----

model Message {
  id        String      @id @default(cuid())
  content   String
  playerId  String
  roomId    String
  channel   ChatChannel @default(PUBLIC)
  createdAt DateTime    @default(now())
  player    Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  room      Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, channel])
  @@index([createdAt])
}

// ---- Oyun Logu ----

model GameLog {
  id        String   @id @default(cuid())
  roomId    String
  dayCount  Int
  phase     String
  action    String
  detail    String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

// ---- Enum'lar ----

enum RoomStatus {
  WAITING
  PLAYING
  ENDED
}

enum Role {
  MAFYA
  DOKTOR
  DEDEKTIF
  VATANDAS
}

enum ChatChannel {
  PUBLIC
  MAFIA
}
